{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "include": [
    "env.d.ts",
    "src/index.ts",
    "src/components/gantt-editor-lib/**/*.ts",
    "src/vue/**/*.ts",
    "src/vue/**/*.vue"
  ],
  "exclude": ["src/**/__tests__/*", "src/react/**/*", "src/angular/**/*"],
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "es2024",
    "lib": ["ES2024", "DOM", "DOM.Iterable"],
    "types": ["node", "vite/client"],
    "paths": {
      "@/*": ["./src/*"]
    }
  }
}
