{
  "name": "@pf/gantt-editor-vue-component",
  "private": false,
  "type": "module",
  "version": "0.4.0",
  "main": "./dist/gantt-editor-vue-component.umd.js",
  "module": "./dist/gantt-editor-vue-component.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/gantt-editor-vue-component.es.js",
      "require": "./dist/gantt-editor-vue-component.umd.js"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "npm run build-only && npm run build:types",
    "preview": "vite preview",
    "build-only": "vite build",
    "build:types": "vue-tsc src/index.ts --declaration --emitDeclarationOnly --outDir dist",
    "lint": "eslint . --fix",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed"
  },
  "dependencies": {
    "@fontsource/roboto": "5.2.5",
    "@mdi/font": "7.4.47",
    "d3": "^7.9.0",
    "vue": "^3.5.13",
    "vuetify": "^3.8.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.1",
    "@tsconfig/node22": "^22.0.0",
    "@types/d3": "^7.4.3",
    "@types/node": "^22.9.0",
    "@vitejs/plugin-vue": "^5.2.3",
    "@vue/tsconfig": "^0.7.0",
    "eslint": "^9.23.0",
    "eslint-config-vuetify": "^4.0.0",
    "npm-run-all2": "^7.0.2",
    "sass-embedded": "^1.86.3",
    "typescript": "~5.8.2",
    "unplugin-fonts": "^1.3.1",
    "unplugin-vue-components": "^28.4.1",
    "unplugin-vue-router": "^0.12.0",
    "vite": "^6.2.2",
    "vite-plugin-vuetify": "^2.1.1",
    "vue-router": "^4.5.0",
    "vue-tsc": "^2.2.8"
  }
}
