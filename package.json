{
  "name": "@pf/gantt-editor-vue-component",
  "private": false,
  "workspaces": [
    "apps/*"
  ],
  "type": "module",
  "version": "2.5.0",
  "main": "./dist/vue/index.cjs",
  "module": "./dist/vue/index.js",
  "types": "./dist/vue/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/vue/index.d.ts",
      "import": "./dist/vue/index.js",
      "require": "./dist/vue/index.cjs"
    },
    "./vue": {
      "types": "./dist/vue/index.d.ts",
      "import": "./dist/vue/index.js",
      "require": "./dist/vue/index.cjs"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js",
      "require": "./dist/react/index.cjs"
    },
    "./angular": {
      "types": "./dist/angular/index.d.ts",
      "import": "./dist/angular/index.js",
      "require": "./dist/angular/index.cjs"
    },
    "./style.css": "./dist/vue/style.css",
    "./vue/style.css": "./dist/vue/style.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "npm run dev:vue",
    "dev:vue": "npm run dev --workspace @pf/gantt-editor-demo-vue",
    "dev:react": "npm run dev --workspace @pf/gantt-editor-demo-react",
    "dev:angular": "npm run dev --workspace @pf/gantt-editor-demo-angular",
    "build": "npm run clean && npm run build-only && npm run build:types && npm run build:wrappers",
    "preview": "vite preview",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "build-only": "vite build",
    "build:types": "vue-tsc -p tsconfig.types.json --declaration --emitDeclarationOnly --outDir dist",
    "build:wrappers": "tsup",
    "lint": "eslint . --fix",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:coverage": "node -e \"require('fs').rmSync('.nyc_output',{recursive:true,force:true})\" && cross-env PW_E2E_COVERAGE=1 playwright test && node -e \"require('fs').mkdirSync('.nyc_output',{recursive:true})\" && nyc report --temp-dir .nyc_output --reporter=text-summary --reporter=html --report-dir test-results/e2e-coverage && http-server test-results/e2e-coverage -p 4173 -c-1"
  },
  "dependencies": {
    "vue": "^3.5.13"
  },
  "peerDependencies": {
    "@angular/common": "^17.0.0 || ^18.0.0 || ^19.0.0 || ^20.0.0",
    "@angular/core": "^17.0.0 || ^18.0.0 || ^19.0.0 || ^20.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "@angular/common": {
      "optional": true
    },
    "@angular/core": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@angular/common": "^20.3.4",
    "@angular/core": "^20.3.4",
    "@playwright/test": "^1.58.1",
    "@tsconfig/node22": "^22.0.0",
    "@types/node": "^22.19.17",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-vue": "^5.2.3",
    "@vue/tsconfig": "^0.7.0",
    "cross-env": "^10.1.0",
    "eslint": "^9.23.0",
    "http-server": "^14.1.1",
    "npm-run-all2": "^7.0.2",
    "nyc": "^18.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tsup": "^8.5.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.2",
    "vite-plugin-istanbul": "^8.0.0",
    "vite-plugin-lib-inject-css": "^2.2.2",
    "vue-tsc": "^2.2.8"
  }
}
