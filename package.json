{
  "name": "@pf/gantt-editor-vue-component",
  "private": false,
  "type": "module",
  "version": "2.5.0",
  "main": "./dist/gantt-editor-vue-component.umd.js",
  "module": "./dist/gantt-editor-vue-component.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/gantt-editor-vue-component.es.js",
      "require": "./dist/gantt-editor-vue-component.umd.js"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "npm run build-only && npm run build:types",
    "preview": "vite preview",
    "build-only": "vite build",
    "build:types": "vue-tsc -p tsconfig.types.json --declaration --emitDeclarationOnly --outDir dist",
    "lint": "eslint . --fix",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:coverage": "node -e \"require('fs').rmSync('.nyc_output',{recursive:true,force:true})\" && cross-env PW_E2E_COVERAGE=1 playwright test && node -e \"require('fs').mkdirSync('.nyc_output',{recursive:true})\" && nyc report --temp-dir .nyc_output --reporter=text-summary --reporter=html --report-dir test-results/e2e-coverage && http-server test-results/e2e-coverage -p 4173 -c-1"
  },
  "dependencies": {
    "@chenglou/pretext": "^0.0.5",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.1",
    "@tsconfig/node22": "^22.0.0",
    "@types/node": "^22.19.17",
    "@vitejs/plugin-vue": "^5.2.3",
    "@vue/tsconfig": "^0.7.0",
    "cross-env": "^10.1.0",
    "eslint": "^9.23.0",
    "http-server": "^14.1.1",
    "npm-run-all2": "^7.0.2",
    "nyc": "^18.0.0",
    "typescript": "~5.8.2",
    "unplugin-vue-router": "^0.12.0",
    "vite": "^6.2.2",
    "vite-plugin-istanbul": "^8.0.0",
    "vite-plugin-lib-inject-css": "^2.2.2",
    "vue-router": "^4.5.0",
    "vue-tsc": "^2.2.8"
  }
}
