{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "noEmit": false,
    "composite": false,
    "incremental": false,
    "rootDir": ".",
  },
  "include": [
    "env.d.ts",
    "src/index.ts",
    "src/components/gantt-editor-lib/**/*.ts",
    "src/vue/**/*.ts",
    "src/vue/**/*.vue"
  ],
  "exclude": [
    "src/react/**/*",
    "src/angular/**/*",
    "tests/**/*"
  ]
}
