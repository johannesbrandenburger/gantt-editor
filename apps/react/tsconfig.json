{
  "compilerOptions": {
    "target": "es2024",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2024", "DOM", "DOM.Iterable"],
    "types": ["node", "vite/client"],
    "strict": true,
    "jsx": "react-jsx",
    "skipLibCheck": true
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "../../src/components/gantt-editor-lib/**/*.ts",
    "../../src/react/**/*.ts",
    "../../src/react/**/*.tsx"
  ],
  "exclude": [
    "../../tests/**/*"
  ]
}
