{
  "compilerOptions": {
    "target": "es2024",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2024", "DOM", "DOM.Iterable"],
    "types": ["node", "vite/client"],
    "strict": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["../../src/*"],
      "@app/*": ["./src/*"]
    }
  },
  "include": [
    "env.d.ts",
    "src/**/*.ts",
    "src/**/*.vue",
    "../../src/components/gantt-editor-lib/**/*.ts",
    "../../src/vue/**/*.ts",
    "../../src/vue/**/*.vue"
  ],
  "exclude": [
    "../../tests/**/*"
  ]
}
