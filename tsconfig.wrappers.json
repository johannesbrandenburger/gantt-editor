{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2024", "DOM", "DOM.Iterable"],
    "useDefineForClassFields": true,
    "composite": false,
    "incremental": false,
    "jsx": "react-jsx",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": false,
    "types": ["node", "vite/client", "react", "react-dom"],
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true
  },
  "include": [
    "env.d.ts",
    "src/react/**/*.ts",
    "src/react/**/*.tsx",
    "src/angular/**/*.ts",
    "src/components/gantt-editor-lib/**/*.ts"
  ],
  "exclude": [
    "src/**/*.vue",
    "src/main.ts",
    "src/App.vue",
    "src/router/**/*",
    "src/plugins/**/*",
    "src/pages/**/*",
    "tests/**/*"
  ]
}